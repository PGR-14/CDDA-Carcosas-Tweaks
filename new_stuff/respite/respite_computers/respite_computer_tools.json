  {
    "id": "EOC_RESPITE_COMP_ORDER_TOOLS",
    "type": "effect_on_condition",
    "condition": { "expects_vars": [ "name", "max" ] },
    "effect": [
      {
        "set_string_var": "u_number_fabricate_<context_val:name>",
        "target_var": { "context_val": "item" },
        "parse_tags": true
      },
      { "math": [ "v_item = clamp(num_input('', v_item), 0, _max)" ] },
      { "math": [ "u_number_fabricate_price = 0" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_goggles_welding * 2" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_welding_mask * 3" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_oxy_torch * 5" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_tinyweldtank * 5" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_smallweldtank * 20" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_weldtank * 80" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_hacksaw" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_chisel * 2" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_hotcut" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_drift" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_swage * 2" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_metalworking_tongs * 3" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_crucible * 4" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_sewing_kit * 2" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_tailors_kit * 4" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_ax * 4" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_hatchet * 2" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_saw" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_hammer" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_cordless_drill * 2" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_cordless_impact_wrench * 2" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_light_minus_battery_cell / 60" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_light_cell_rechargeable / 15" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_medium_battery_cell / 3" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_heavy_battery_cell * 2" ] },
      { "math": [ "u_number_fabricate_price += u_number_fabricate_heavy_plus_battery_cell * 4" ] },
      {
        "run_eocs": {
          "id": "EOC_RESPITE_COMP_ORDERED_TOOLS",
          "condition": { "u_has_items": { "item": "FMCNote", "count": { "math": [ "u_number_fabricate_price" ] } } },
          "effect": [
            { "u_consume_item_sum": [ { "item": "FMCNote", "amount": { "math": [ "u_number_fabricate_price" ] } } ] },
            {
              "foreach": "array",
              "var": { "context_val": "name" },
              "target": [
                "goggles_welding",
                "welding_mask",
                "oxy_torch",
                "tinyweldtank",
                "smallweldtank",
                "weldtank",
                "hacksaw",
                "chisel",
                "hotcut",
                "drift",
                "swage",
                "metalworking_tongs",
                "crucible",
                "sewing_kit",
                "tailors_kit",
                "ax",
                "hatchet",
                "saw",
                "hammer",
                "cordless_drill",
                "cordless_impact_wrench",
                "light_minus_battery_cell",
                "light_cell_rechargeable",
                "medium_battery_cell",
                "heavy_battery_cell",
                "heavy_plus_battery_cell"
              ],
              "effect": [
                {
                  "set_string_var": "u_number_fabricate_<context_val:name>",
                  "target_var": { "context_val": "item" },
                  "parse_tags": true
                },
                {
                  "if": { "math": [ "v_item != 0" ] },
                  "then": { "u_spawn_item": { "context_val": "name" }, "count": { "var_val": "item" } }
                }
              ]
            }
          ],
          "false_effect": [ { "open_dialogue": { "topic": "RESPITE_COMP_NO_CASH_TOOLS" } }, { "run_eocs": [ "EOC_RESPITE_COMP_RESET_TOOLS" ] } ]
        }
      }
    ]
  },
